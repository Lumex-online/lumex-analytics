PORT=4001
WEB_ORIGIN=http://localhost:5173
DEFAULT_SOURCE_USER_ID=1
ANALYTICS_STORE=mongo
ANALYTICS_ALLOW_UNAUTHENTICATED_MONGO=false

# Lumex source dataset mode: mongo, api, or files.
LUMEX_DATA_SOURCE=mongo
LUMEX_MONGO_URI=mongodb://analytics_reader:CHANGE_ME@localhost:27017/lumex?authSource=lumex
LUMEX_MONGO_DATABASE=lumex

# Analytics warehouse. This must use a different Mongo user than LUMEX_MONGO_URI.
ANALYTICS_MONGO_URI=mongodb://analytics_writer:CHANGE_ME@localhost:27017/lumex_analytics?authSource=lumex_analytics
ANALYTICS_MONGO_DATABASE=lumex_analytics

# HTTP fallback, used when LUMEX_DATA_SOURCE=api.
LUMEX_API_BASE_URL=http://localhost:8000
LUMEX_API_PATH_PREFIX=api/api/v1
LUMEX_API_AUTH_HEADER=Authorization
LUMEX_API_AUTH_TOKEN=
LUMEX_API_TIMEOUT_MS=30000

# Optional per-collection overrides
LUMEX_API_URL_BUYERS=http://localhost:8000/api/api/v1/buyers
LUMEX_API_URL_CLARITIES=http://localhost:8000/api/api/v1/clarities
LUMEX_API_URL_COLORS=http://localhost:8000/api/api/v1/colors
LUMEX_API_URL_LOOSE_LOTS_MASTER=http://localhost:8000/api/api/v1/looseLotsMaster
LUMEX_API_URL_LOOSE_LOTS_ORDERS=http://localhost:8000/api/api/v1/looseLotsOrders
LUMEX_API_URL_LOOSE_LOTS_PURCHASES=http://localhost:8000/api/api/v1/looseLotsPurchases
LUMEX_API_URL_INVENTORY=http://localhost:8000/api/api/v1/inventory
LUMEX_API_URL_MEMOS=http://localhost:8000/api/api/v1/memos
LUMEX_API_URL_ORDERS=http://localhost:8000/api/api/v1/orders
LUMEX_API_URL_ORDER_RETURNS=http://localhost:8000/api/api/v1/orderReturns
LUMEX_API_URL_OWN_SHAPE_MASTER=http://localhost:8000/api/api/v1/ownShapeMaster
LUMEX_API_URL_OWN_SHAPE_ORDERS=http://localhost:8000/api/api/v1/ownShapeOrders
LUMEX_API_URL_SHAPES=http://localhost:8000/api/api/v1/shapes
LUMEX_API_URL_SUB_ADMINS=http://localhost:8000/api/api/v1/subAdmins
LUMEX_API_URL_USERS=http://localhost:8000/api/api/v1/users
LUMEX_API_URL_VENDORS=http://localhost:8000/api/api/v1/vendors
LUMEX_API_URL_WAREHOUSES=http://localhost:8000/api/api/v1/warehouses
LUMEX_API_URL_WAREHOUSE_PURCHASES=http://localhost:8000/api/api/v1/warehousePurchases
