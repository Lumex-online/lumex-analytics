{
  "name": "@lumex/jobs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:once": "node dist/index.js --once",
    "setup": "node dist/setup.js",
    "setup:dev": "tsx src/setup.ts",
    "test": "node --import tsx --test src/persist/mongo/common.test.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lumex/lumex-source": "0.1.0",
    "@lumex/shared-types": "0.1.0",
    "mongodb": "^6.9.0",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.3"
  }
}
