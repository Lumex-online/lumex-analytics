# Lumex Analytics environment template.
#
# Runtime files:
# - .env: local active file, used by npm run dev, setup, jobs, and fallback scripts
# - .env.dev: hosted/dev server, used by npm run dev:dev
# - .env.prod: production server, used by build/start/setup scripts
#
# Keep only one local active env file. Do not create .env.local for this app,
# because Vite auto-loads it and can override the secure .env values.
#
# Do not put NODE_ENV in these files. Use ANALYTICS_ENV instead.
# Production/staging secrets must be changed before deploy.

ANALYTICS_ENV=dev
PORT=4001

# Comma-separated browser origins allowed by API CORS.
# Local: http://localhost:3001,http://localhost:5173
# Production example: https://app.lumex.online,https://analytics.lumex.online,https://lumex.online
WEB_ORIGIN=https://devadmin.lumex.online,https://devanalytics.lumex.online,http://localhost:3001,http://localhost:5173

# Secure local/admin-embedded testing uses backend-issued embed tokens.
# Keep fallback disabled except for throwaway standalone local debugging.
DEFAULT_SOURCE_USER_ID=0
ANALYTICS_PROXY_USER_HEADER=x-analytics-source-user-id
ANALYTICS_PROXY_SECRET_HEADER=x-analytics-proxy-secret
ANALYTICS_PROXY_SECRET=CHANGE_TO_DEV_RANDOM_SECRET
ANALYTICS_EMBED_TOKEN_SECRET=CHANGE_TO_DEV_ANALYTICS_EMBED_TOKEN_SECRET

# Analytics storage. Production must use mongo and must not allow unauthenticated Mongo.
ANALYTICS_STORE=mongo
ANALYTICS_ALLOW_UNAUTHENTICATED_MONGO=true

# Lumex source data. Production must use mongo.
LUMEX_DATA_SOURCE=mongo
LUMEX_MONGO_URI=mongodb://localhost:27017/lumex
LUMEX_MONGO_DATABASE=lumex

# Analytics warehouse.
ANALYTICS_MONGO_URI=mongodb://localhost:27017/lumex_analytics
ANALYTICS_MONGO_DATABASE=lumex_analytics

# Jobs.
ETL_BATCH_SIZE=500
ETL_RUN_ON_BOOT=false
LUMEX_DUMP_DIR=

# Web.
# Local dev calls the API directly. Hosted dev/prod should use /api/v1 behind nginx.
VITE_API_BASE_URL=http://localhost:4001/api/v1
VITE_ANALYTICS_ENV=dev
VITE_SOURCE_USER_ID=

# Optional HTTP source fallback, used only when LUMEX_DATA_SOURCE=api outside production.
LUMEX_API_BASE_URL=http://localhost:8000
LUMEX_API_PATH_PREFIX=api/api/v1
LUMEX_API_AUTH_HEADER=Authorization
LUMEX_API_AUTH_TOKEN=
LUMEX_API_TIMEOUT_MS=30000

# Optional per-collection API override pattern:
# LUMEX_API_URL_<COLLECTION_KEY>=http://localhost:8000/api/api/v1/<endpoint>
#
# Production values must be hardened, for example:
# ANALYTICS_ENV=prod
# WEB_ORIGIN=https://app.lumex.online,https://analytics.lumex.online,https://lumex.online
# ANALYTICS_PROXY_SECRET=<long-random-secret>
# ANALYTICS_EMBED_TOKEN_SECRET=<same-secret-configured-in-lumex-backend>
# ANALYTICS_ALLOW_UNAUTHENTICATED_MONGO=false
# LUMEX_MONGO_URI=mongodb://analytics_reader:<password>@127.0.0.1:27017/lumex?authSource=lumex
# ANALYTICS_MONGO_URI=mongodb://analytics_writer:<password>@127.0.0.1:27017/lumex_analytics?authSource=lumex_analytics
# VITE_API_BASE_URL=/api/v1
# VITE_ANALYTICS_ENV=prod
# VITE_SOURCE_USER_ID=
